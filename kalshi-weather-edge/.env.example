# =============================================================================
# Kalshi Weather Edge — .env.example
# Copy this file to .env and fill in local values.
#
# NEVER commit .env.
# NEVER paste real keys into ChatGPT, Claude, Codex, GitHub, docs, or logs.
# This project should remain research/read-only unless separately reviewed.
# =============================================================================


# =============================================================================
# Runtime
# =============================================================================

ENVIRONMENT=local
LOG_LEVEL=INFO

DATA_DIR=data
REPORTS_DIR=reports
DATABASE_PATH=data/weather_edge.sqlite


# =============================================================================
# Kalshi API — READ-ONLY / RESEARCH USE
# =============================================================================
# Use these only for market discovery, market metadata, and orderbook snapshots.
# Do not use them for order placement unless a future reviewed task explicitly adds that.

KALSHI_API_KEY_ID=your_kalshi_key_id_here
KALSHI_API_PRIVATE_KEY_PATH=C:\Users\mason\Downloads\prediction-markets-program\kalshi_private_key.pem

# Optional environment/base URL settings.
KALSHI_ENV=prod
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2


# =============================================================================
# Weather Data Sources
# =============================================================================
# NWS generally does not require an API key, but a User-Agent/contact is good practice.

NWS_USER_AGENT=kalshi-weather-edge/0.1 your_email@example.com

# Optional NOAA token if a future command uses NOAA token-auth endpoints.
NOAA_TOKEN=

# IEM/ASOS public data source.
IEM_BASE_URL=https://mesonet.agron.iastate.edu

# Default timezone for reports/parsing if needed.
DEFAULT_TIMEZONE=America/New_York


# =============================================================================
# Collectors
# =============================================================================

# Kalshi orderbook collector defaults.
ORDERBOOK_INTERVAL_SECONDS=30
ORDERBOOK_MAX_MARKETS=100
ORDERBOOK_WEATHER_ONLY=true

# Weather observation collector defaults.
WEATHER_OBSERVATION_INTERVAL_MINUTES=5

# Weather forecast collector defaults.
WEATHER_FORECAST_INTERVAL_MINUTES=30


# =============================================================================
# Replay / Evidence
# =============================================================================

DEFAULT_LOOKBACK_DAYS=7
DEFAULT_MAX_MARKETS=25

# Keep false unless a command explicitly needs it.
ENABLE_FORCE_REBUILD_REPLAY=false

# Never allow destructive database actions by default.
ENABLE_DESTRUCTIVE_DB_OPS=false


# =============================================================================
# Safety Flags
# =============================================================================

RESEARCH_ONLY=true
REQUIRE_READ_ONLY_MODE=true

ENABLE_LIVE_TRADING=false
ENABLE_ORDER_PLACEMENT=false
ENABLE_ACCOUNT_BALANCE_READS=false
ENABLE_WALLET_SIGNING=false
ENABLE_PRIVATE_KEY_USAGE=false