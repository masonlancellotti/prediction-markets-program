MAX_TRADE_DOLLARS=5
MAX_MARKET_EXPOSURE=20
MAX_TOTAL_EXPOSURE=100
MAX_DAILY_LOSS=25
MIN_EDGE_CENTS=7
MIN_SPREAD_CENTS=4
MAX_WEATHER_DATA_AGE_MINUTES=15
ALLOW_MARKET_ORDERS=false
ORDERBOOK_RECORD_INTERVAL_SECONDS=30
ORDERBOOK_RECORD_WEATHER_ONLY=true
ORDERBOOK_RECORD_MAX_MARKETS=100
ORDERBOOK_RECORD_FULL_DEPTH=true
KALSHI_MARKETS_REFRESH_SECONDS=300
KALSHI_MARKETS_REFRESH_FAILURE_BACKOFF_SECONDS=600
KALSHI_ORDERBOOK_SLEEP_BETWEEN_REQUESTS_MS=100
KALSHI_MAX_RETRIES=5
KALSHI_BACKOFF_MAX_SECONDS=60
MIN_SETTLEMENT_CONFIDENCE_PRIMARY=0.85

COLLECTOR_DEFAULT_DURATION_HOURS=72
COLLECTOR_SCAN_INTERVAL_MINUTES=5
COLLECTOR_MAINTENANCE_INTERVAL_MINUTES=60
COLLECTOR_SETTLEMENT_LOOKBACK_DAYS=10
