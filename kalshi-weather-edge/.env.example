COLLECTOR_LOG_SUMMARY_EVERY_CYCLES=10
WEATHER_OBSERVATION_RECORD_INTERVAL_MINUTES=5
WEATHER_FORECAST_RECORD_INTERVAL_MINUTES=30

PASSIVE_ASSUME_TOUCH_FILL=false
PASSIVE_DEFAULT_FILL_HAIRCUT=0.25
PASSIVE_ADVERSE_SELECTION_PENALTY_CENTS=2
PASSIVE_REQUIRE_TRADED_THROUGH=true
PASSIVE_MIN_SPREAD_CENTS=8
