# =============================================================================
# Relative Value Scanner — .env.example
# Copy this file to .env and fill in local values.
#
# NEVER commit .env.
# NEVER paste real keys into ChatGPT, Claude, Codex, GitHub, docs, or logs.
# This project should remain read-only / research-only unless separately reviewed.
# =============================================================================


# =============================================================================
# Runtime
# =============================================================================

ENVIRONMENT=local
LOG_LEVEL=INFO
REPORTS_DIR=reports

# Default scanner mode should remain offline/static unless an explicit live-read-only
# command is reviewed and run.
DEFAULT_DATA_SOURCE_MODE=STATIC_FIXTURE


# =============================================================================
# The Odds API — REFERENCE_ONLY
# =============================================================================
# Used for sportsbook/reference odds only.
# This source is not executable and must not create PAPER_CANDIDATE.

THE_ODDS_API_KEY=

THE_ODDS_API_REGION=us
THE_ODDS_API_MARKETS=h2h,spreads,totals
THE_ODDS_API_ODDS_FORMAT=american
THE_ODDS_API_DATE_FORMAT=iso


# =============================================================================
# Kalshi — EXECUTABLE VENUE, READ-ONLY FOR CURRENT PROJECT STAGE
# =============================================================================
# Use only for market discovery, metadata, and orderbook reads.
# Do not use for order placement unless a future reviewed task explicitly adds it.

KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY_PATH=

KALSHI_ENV=prod
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2


# =============================================================================
# Polymarket — PUBLIC READ-ONLY DATA FOR CURRENT PROJECT STAGE
# =============================================================================
# Public endpoints are enough for market discovery and orderbook research.
# Do not add private keys/signing unless a future reviewed task explicitly requires it.

POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

POLYMARKET_READ_ONLY=true
POLYMARKET_ENABLE_TRADING=false
POLYMARKET_ENABLE_PRIVATE_KEY=false

# FORBIDDEN FOR NOW:
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=


# =============================================================================
# SX Bet — PLANNED_NOT_IMPLEMENTED / READ-ONLY RESEARCH ONLY
# =============================================================================
# Current code should remain fixture/design-only unless separately reviewed.
# Do not add wallet/private-key/signing values here.

SX_BET_BASE_URL=https://api.sx.bet
SX_BET_ENABLED=false
SX_BET_READ_ONLY=true

# FORBIDDEN FOR NOW:
# SX_BET_PRIVATE_KEY=
# SX_BET_WALLET_ADDRESS=
# SX_BET_SIGNING_KEY=
# SX_BET_AUTH_TOKEN=


# =============================================================================
# IBKR / ForecastEx — PLANNED_NOT_IMPLEMENTED EXECUTABLE VENUE
# =============================================================================
# Use only after account permission + adapter review.
# Keep disabled until code support is reviewed.

IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=
IBKR_TRADING_MODE=paper

FORECASTEX_ENABLED=false


# =============================================================================
# ProphetX — DO_NOT_USE_YET / API REVIEW NEEDED
# =============================================================================
# Fill only if ProphetX grants API access and a reviewed read-only adapter exists.

PROPHETX_ENABLED=false
PROPHETX_BASE_URL=
PROPHETX_API_KEY=
PROPHETX_API_SECRET=


# =============================================================================
# Crypto.com Event Contracts — DO_NOT_USE_YET / API UNCLEAR
# =============================================================================

CRYPTO_COM_ENABLED=false
CRYPTO_COM_BASE_URL=
CRYPTO_COM_API_KEY=
CRYPTO_COM_API_SECRET=


# =============================================================================
# Robinhood Event Contracts — DO_NOT_USE_YET / API UNCLEAR
# =============================================================================
# Do not use browser automation or username/password/session scraping.

ROBINHOOD_ENABLED=false

# FORBIDDEN FOR NOW:
# ROBINHOOD_USERNAME=
# ROBINHOOD_PASSWORD=
# ROBINHOOD_SESSION_TOKEN=


# =============================================================================
# Global Safety Flags
# =============================================================================

ENABLE_LIVE_FETCH=false
ENABLE_ORDER_PLACEMENT=false
ENABLE_WALLET_SIGNING=false
ENABLE_PRIVATE_KEY_USAGE=false

REQUIRE_READ_ONLY_MODE=true
RESEARCH_ONLY=true
